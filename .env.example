MAIL_DOMAIN=example.com
MAIL_HOSTNAME=mail.example.com
MAIL_ADMIN_JWT_SECRET=change-this-jwt-secret
MAIL_ADMIN_JWT_ISSUER=ucware-mail-admin
MAIL_ADMIN_JWT_EXPIRY_MINUTES=60
MAIL_ADMIN_EMAIL=admin@example.com
MAIL_ADMIN_PASSWORD=ChangeMeAdmin!123
MAIL_ADMIN_ROLE=admin

# ── OAuth2 (선택) ────────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials 에서 OAuth 2.0 클라이언트 ID 생성
OAUTH2_CALLBACK_BASE=http://localhost:8080
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# Microsoft: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps 에서 앱 등록
MICROSOFT_OAUTH2_CLIENT_ID=
MICROSOFT_OAUTH2_CLIENT_SECRET=
MICROSOFT_TENANT=common

# ── TOTP ────────────────────────────────────────────────────────────────────
TOTP_ISSUER=ucware-mail-admin
TOTP_CHALLENGE_EXPIRY_MINUTES=5

# ── Mail Security Policy (선택) ─────────────────────────────────────────────
# Antivirus provider: clamav | v3 | none
ANTIVIRUS_PROVIDER=clamav

# milter 장애 시 정책: yes(accept) | no(tempfail)
ANTIVIRUS_FAIL_OPEN=yes

# ANTIVIRUS_PROVIDER=v3 일 때 사용 (외부 ICAP 게이트웨이)
# 예: 10.0.0.5:1344
# 로컬 mock 검증 시: mock-icap:1344 (v3mock profile)
ANTIVIRUS_V3_ICAP_SERVER=
ANTIVIRUS_V3_ICAP_SCHEME=respmod

# ── Archive DB (수신/발신 메일 저장) ───────────────────────────────────────
ARCHIVE_DB_ENABLED=false
# 지원: postgres | mysql | oracle
ARCHIVE_DB_DRIVER=postgres
# 예시(PostgreSQL): postgres://user:pass@localhost:5432/mailarchive?sslmode=disable
# 예시(MySQL): user:pass@tcp(localhost:3306)/mailarchive?parseTime=true
# 예시(Oracle): oracle://user:pass@localhost:1521/XEPDB1
ARCHIVE_DSN=

# ── App POP3 Server (선택) ─────────────────────────────────────────────────
# true 일 때 mail-admin 앱 내장 POP3 서버 사용
APP_POP3_ENABLED=false
# host:container 매핑의 host 포트
APP_POP3_PORT=2111
