# 대용량 운영 예시용 환경 변수 파일
# 사용 예:
#   cp .env.large.example .env.large
#   docker compose --env-file .env.large -f docker-compose_large.yml up -d --build

# ── 공통 식별 정보 ─────────────────────────────────────────────────────────
MAIL_DOMAIN=example.com
MAIL_HOSTNAME=mail-lb.example.com

# ── mail-admin API 인증 ───────────────────────────────────────────────────
MAIL_ADMIN_JWT_SECRET=replace-with-very-strong-random-secret
MAIL_ADMIN_JWT_ISSUER=ucware-mail-admin-large
MAIL_ADMIN_JWT_EXPIRY_MINUTES=60
MAIL_ADMIN_EMAIL=admin@example.com
MAIL_ADMIN_PASSWORD=ChangeMeAdmin!123
MAIL_ADMIN_ROLE=admin

# ── 아카이브 DB ───────────────────────────────────────────────────────────
ARCHIVE_DB_ENABLED=true
ARCHIVE_DB_DRIVER=postgres
ARCHIVE_DB_USER=mail
ARCHIVE_DB_PASSWORD=mailpw
ARCHIVE_DB_NAME=mailarchive
ARCHIVE_DSN=postgres://mail:mailpw@archive-db:5432/mailarchive?sslmode=disable

# ── SMTP Relay / Send API ─────────────────────────────────────────────────
# 대용량 예시에서는 각 mail-admin 인스턴스가 가까운 postfix 노드를 기본 릴레이로 사용
SMTP_USERNAME=
SMTP_PASSWORD=

# ── 보안 정책 ─────────────────────────────────────────────────────────────
# clamav | v3 | none
ANTIVIRUS_PROVIDER=clamav
# yes(가용성 우선) | no(보안 우선)
ANTIVIRUS_FAIL_OPEN=yes
ANTIVIRUS_V3_ICAP_SERVER=
ANTIVIRUS_V3_ICAP_SCHEME=respmod

# ── API 보호 정책 ─────────────────────────────────────────────────────────
LOGIN_IP_RATE_LIMIT_PER_MIN=60
LOGIN_FAIL_THRESHOLD=5
LOGIN_LOCK_MINUTES=15
SEND_RATE_LIMIT_PER_MIN=120

# ── LMTP / POP3 (선택) ────────────────────────────────────────────────────
APP_POP3_ENABLED=false
LMTP_ENABLED=false
LMTP_MAX_MESSAGE_BYTES=209715200

# ── Nginx HTTPS 종료 예시값 ───────────────────────────────────────────────
NGINX_SERVER_NAME=mail.example.com
NGINX_TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
NGINX_TLS_KEY_PATH=/etc/nginx/certs/privkey.pem

# ── 참고 ─────────────────────────────────────────────────────────────────
# 이 파일은 docker-compose_large.yml 예시용이며,
# 실제 운영에서는 중앙 DB, 중앙 설정 저장소, 비밀관리 시스템을 함께 사용해야 합니다.
