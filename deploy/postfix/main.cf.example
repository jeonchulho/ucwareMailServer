# Basic identity
# 서버 고유 식별 정보
myhostname = mail.example.com
myorigin = /etc/mailname
inet_interfaces = all
inet_protocols = ipv4

# Relay policy
# 릴레이 허용 정책: 내부망/인증 사용자만 허용
mynetworks = 127.0.0.0/8 [::1]/128
smtpd_recipient_restrictions =
    permit_mynetworks,
    permit_sasl_authenticated,
    reject_unauth_destination

# TLS (set real cert paths)
# 인증서 경로를 실제 발급 경로로 교체해야 한다.
smtpd_use_tls = yes
smtpd_tls_cert_file = /etc/letsencrypt/live/mail.example.com/fullchain.pem
smtpd_tls_key_file = /etc/letsencrypt/live/mail.example.com/privkey.pem
smtpd_tls_security_level = may

# Virtual mailbox settings (files generated by Go mail-admin)
# 가상 도메인/메일박스 매핑은 mail-admin 동기화 결과를 사용
virtual_mailbox_domains = hash:/etc/postfix/virtual_mailbox_domains
virtual_mailbox_maps = hash:/etc/postfix/virtual_mailbox_maps
virtual_transport = lmtp:unix:private/dovecot-lmtp

# SASL via dovecot
# SMTP AUTH 인증을 Dovecot auth 소켓으로 위임
smtpd_sasl_auth_enable = yes
smtpd_sasl_type = dovecot
smtpd_sasl_path = private/auth
smtpd_sasl_security_options = noanonymous
